public class DateLiteralsDemo {
    /*YESTERDAY – All records with a date field equal to yesterday.
	TODAY – Records with a date field equal to today.
	TOMORROW – Records with a date field equal to tomorrow.
	LAST_WEEK – Records from the previous week (Sunday–Saturday).
	THIS_WEEK – Records from the current week.
	NEXT_WEEK – Records from the upcoming week.
	LAST_MONTH, THIS_MONTH, NEXT_MONTH – Similar for months.
	LAST_N_DAYS:n – Records from the last n days (e.g., LAST_N_DAYS:30).
	NEXT_N_DAYS:n – Records from the next n days.
	LAST_N_WEEKS:n, NEXT_N_WEEKS:n – For weeks.
	LAST_N_MONTHS:n, NEXT_N_MONTHS:n – For months.
	LAST_N_QUARTERS:n, NEXT_N_QUARTERS:n – For quarters.
	LAST_N_YEARS:n, NEXT_N_YEARS:n – For years. */
}